# ─────────────────────────────────────────────────────────────────────────────
# DB MCP — Multi-Database Configuration
# Copy this file to .env and fill in your actual credentials.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Global Settings ─────────────────────────────────────────────────────────
QUERY_TIMEOUT=30000
MAX_ROWS=1000
DEBUG=false

# ─── Database 1: SQL Server ──────────────────────────────────────────────────
# DB_1_NAME is the custom routing key — agents will use this name to target queries.
DB_1_NAME=teste_sqlserver
DB_1_TYPE=sqlserver
DB_1_SERVER=localhost
DB_1_PORT=1433
DB_1_DATABASE=BancoDeTeste
DB_1_BLOCKED_IDENTIFIERS=BancoDeProducao
DB_1_USER=sa
DB_1_PASSWORD=YourPasswordHere
# DB_1_ENCRYPT=true
# DB_1_TRUST_CERT=true
# DB_1_ALLOW_WRITE=true

# ─── Database 2: PostgreSQL ──────────────────────────────────────────────────
# DB_2_NAME=analytics_pg
# DB_2_TYPE=postgresql
# DB_2_SERVER=pg-host.example.com
# DB_2_PORT=5432
# DB_2_DATABASE=analytics
# DB_2_USER=readonly
# DB_2_PASSWORD=YourPasswordHere
# DB_2_SSL=true

# ─── Database 3: MongoDB ─────────────────────────────────────────────────────
# DB_3_NAME=logs_mongo
# DB_3_TYPE=mongodb
# DB_3_SERVER=mongo-host.example.com
# DB_3_PORT=27017
# DB_3_DATABASE=app_logs
# DB_3_USER=reader
# DB_3_PASSWORD=YourPasswordHere
# DB_3_AUTH_SOURCE=admin
# DB_3_CONNECTION_STRING=mongodb+srv://user:pass@cluster.mongodb.net/dbname

# ─── Database 4: Supabase ────────────────────────────────────────────────────
# DB_4_NAME=app_supabase
# DB_4_TYPE=supabase
# DB_4_SERVER=abc123.supabase.co
# DB_4_PORT=5432
# DB_4_DATABASE=postgres
# DB_4_USER=postgres
# DB_4_PASSWORD=YourPasswordHere
# DB_4_SUPABASE_URL=https://abc123.supabase.co
# DB_4_SUPABASE_KEY=eyJ...

# ─── Backward Compatibility ──────────────────────────────────────────────────
# If no DB_1_* variables are set, these legacy variables are used automatically
# with name="default" and type="sqlserver":
# DB_SERVER=localhost
# DB_PORT=1433
# DB_NAME=master
# DB_USER=sa
# DB_PASSWORD=YourPasswordHere
